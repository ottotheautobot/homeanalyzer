SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

SENTRY_DSN=
ENVIRONMENT=development

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

MEETINGBAAS_API_KEY=
MEETINGBAAS_WEBHOOK_SECRET=

# Zoom Meeting SDK credentials. Create a "General App" in Zoom Marketplace,
# enable "Meeting SDK" under Embed, copy SDK Key and SDK Secret. App stays in
# development mode — no review needed for personal/own-account use.
ZOOM_SDK_ID=
ZOOM_SDK_SECRET=

DEEPGRAM_API_KEY=

# Vision pipeline toggle. Default true. Set ENABLE_VISION_ANALYSIS=false to
# skip the post-meeting frame-extraction + Haiku vision call (saves ~$0.25
# per tour). Synthesis still works on audio-only observations.
ENABLE_VISION_ANALYSIS=true

# Resend (transactional emails to tour participants when a tour starts).
# Free tier covers 100 emails/day. Leave blank to disable notifications.
RESEND_API_KEY=
# Default from-address. resend.dev addresses work without domain verification
# but emails are marked as "via resend.dev" and may go to spam. For production
# use, verify your domain in Resend and switch to noreply@yourdomain.com.
RESEND_FROM_EMAIL=Tour Notes <onboarding@resend.dev>

# Used to sign per-bot streaming URL tokens (HMAC). Generate any 32+ char value
# in production; this protects the WS endpoint from internet randos hitting it.
STREAMING_URL_SECRET=
